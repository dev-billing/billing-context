{
  "openapi": "3.0.3",
  "info": {
    "title": "Todo Service API",
    "version": "0.0.1-SNAPSHOT",
    "description": "Todo 항목 관리 REST API. 공개(/api), 내부(/internal/api), 외부(/external/api) 세 그룹으로 구성."
  },
  "servers": [
    { "url": "http://localhost:8080" }
  ],
  "components": {
    "schemas": {
      "TodoStatus": {
        "type": "string",
        "enum": ["TODO", "IN_PROGRESS", "DONE"]
      },
      "TodoCreateRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title":    { "type": "string", "maxLength": 100 },
          "content":  { "type": "string" },
          "dueDate":  { "type": "string", "format": "date" },
          "priority": { "type": "integer", "minimum": 1, "maximum": 5, "description": "1~5 권장, 숫자가 높을수록 중요" },
          "tags":     { "type": "array", "items": { "type": "string" }, "description": "현재 미사용" }
        }
      },
      "TodoUpdateRequest": {
        "type": "object",
        "properties": {
          "title":    { "type": "string" },
          "content":  { "type": "string" },
          "status":   { "$ref": "#/components/schemas/TodoStatus" },
          "dueDate":  { "type": "string", "format": "date" },
          "priority": { "type": "integer", "minimum": 1, "maximum": 5, "description": "1~5 권장" }
        }
      },
      "TodoResponse": {
        "type": "object",
        "properties": {
          "id":        { "type": "integer", "format": "int64" },
          "title":     { "type": "string" },
          "content":   { "type": "string" },
          "status":    { "$ref": "#/components/schemas/TodoStatus" },
          "dueDate":   { "type": "string", "format": "date" },
          "priority":  { "type": "integer", "minimum": 1, "maximum": 5, "description": "1~5" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "StatisticsResponse": {
        "type": "object",
        "properties": {
          "total":   { "type": "integer", "format": "int64" },
          "done":    { "type": "integer", "format": "int64" },
          "pending": { "type": "integer", "format": "int64" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/todo-list/{id}": {
      "get": {
        "tags": ["Public API"],
        "summary": "Todo 단건 조회",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } },
          "404": { "description": "Todo 없음", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "tags": ["Public API"],
        "summary": "Todo 전체 수정",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoUpdateRequest" } } }
        },
        "responses": {
          "200": { "description": "수정 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } },
          "404": { "description": "Todo 없음", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/todo-list": {
      "post": {
        "tags": ["Public API"],
        "summary": "Todo 생성",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoCreateRequest" } } }
        },
        "responses": {
          "201": { "description": "생성 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } }
        }
      }
    },
    "/internal/api/todo-list": {
      "get": {
        "tags": ["Internal API"],
        "summary": "Todo 전체 목록 조회",
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TodoResponse" } } } } }
        }
      },
      "post": {
        "tags": ["Internal API"],
        "summary": "Todo 생성",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoCreateRequest" } } }
        },
        "responses": {
          "201": { "description": "생성 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } }
        }
      }
    },
    "/internal/api/todo-list/{id}": {
      "get": {
        "tags": ["Internal API"],
        "summary": "Todo 단건 조회",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } },
          "404": { "description": "Todo 없음", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/internal/api/todo-list/update/{id}": {
      "put": {
        "tags": ["Internal API"],
        "summary": "Todo 전체 수정",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoUpdateRequest" } } }
        },
        "responses": {
          "200": { "description": "수정 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } },
          "404": { "description": "Todo 없음", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/internal/api/todo-list/delete/{id}": {
      "delete": {
        "tags": ["Internal API"],
        "summary": "Todo 삭제",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "204": { "description": "삭제 성공" },
          "404": { "description": "Todo 없음", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/external/api/todo-list/{id}": {
      "get": {
        "tags": ["External API"],
        "summary": "Todo 단건 조회",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } },
          "404": { "description": "Todo 없음", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "tags": ["External API"],
        "summary": "Todo 수정",
        "description": "`fields` 쿼리 파라미터로 수정할 필드를 한정할 수 있으며, 미입력 시 전체 필드를 덮어씁니다.",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "fields", "in": "query", "required": false, "schema": { "type": "array", "items": { "type": "string", "enum": ["title", "content", "status", "dueDate", "priority"] } }, "description": "업데이트할 필드 목록" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoUpdateRequest" } } }
        },
        "responses": {
          "200": { "description": "수정 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } },
          "404": { "description": "Todo 없음", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "tags": ["External API"],
        "summary": "Todo 삭제",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "204": { "description": "삭제 성공" },
          "404": { "description": "Todo 없음", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/external/api/todo-list/statistics": {
      "get": {
        "tags": ["External API"],
        "summary": "Todo 통계 조회",
        "description": "status 및 minPriority 필터를 조합하여 total/done/pending 카운트 반환 (메모리 집계).",
        "parameters": [
          { "name": "status", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/TodoStatus" }, "description": "필터링할 상태" },
          { "name": "minPriority", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 5 }, "description": "최소 우선순위 (이상)" }
        ],
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatisticsResponse" } } } }
        }
      }
    },
    "/external/api/todo-list/create": {
      "post": {
        "tags": ["External API"],
        "summary": "Todo 생성",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoCreateRequest" } } }
        },
        "responses": {
          "201": { "description": "생성 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TodoResponse" } } } }
        }
      }
    }
  }
}